{
	"$schema": "https://biomejs.dev/schemas/2.4.5/schema.json",
	"files": {
		"ignoreUnknown": false
	},
	"formatter": {
		"enabled": true,
		"indentStyle": "space",
		"indentWidth": 2,
		"lineWidth": 80,
		"lineEnding": "lf",
		"formatWithErrors": true,
		"attributePosition": "auto",
		"bracketSpacing": true
	},
	"linter": {
		"enabled": true,
		"rules": {
			"recommended": true,
			"a11y": {
				"noSvgWithoutTitle": "off",
				"useButtonType": "off"
			},
			"suspicious": {
				"noArrayIndexKey": "info",
				"noThenProperty": "off",
				"noExplicitAny": "off",
				"noAsyncPromiseExecutor": "off",
				"noShadowRestrictedNames": "off"
			},
			"correctness": {
				"useExhaustiveDependencies": "off",
				"noUnreachable": "off",
				"noUnusedImports": "warn"
			},
			"complexity": {
				"noExtraBooleanCast": "off",
				"noUselessCatch": "off",
				"useOptionalChain": "off",
				"noUselessLoneBlockStatements": "off",
				"noForEach": "off",
				"useLiteralKeys": "off"
			},
			"style": {
				"noUselessElse": "off",
				"useImportType": "off"
			}
		}
	},
	"javascript": {
		"formatter": {
			"arrowParentheses": "always",
			"jsxQuoteStyle": "single",
			"quoteProperties": "asNeeded",
			"quoteStyle": "single",
			"semicolons": "always",
			"trailingCommas": "es5",
			"bracketSpacing": true
		}
	}
}
